---
---
<div class="bg-white rounded-2xl shadow-xl shadow-indigo-500/5 border border-slate-200/60 overflow-hidden flex flex-col h-[650px] animate-fade-in-up">
  <!-- Header -->
  <div class="bg-slate-900 p-5 flex items-center justify-between relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-primary-600/20 to-indigo-600/20 pointer-events-none"></div>
    <div class="flex items-center text-white gap-3 relative z-10">
      <div class="p-2.5 bg-gradient-to-br from-primary-500 to-emerald-600 rounded-xl shadow-lg animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
      </div>
      <div>
        <h3 class="font-bold text-lg font-display tracking-tight">AI 智能选卡</h3>
        <div class="flex items-center gap-1.5">
          <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
          <p class="text-[10px] text-slate-400 font-medium uppercase tracking-wider">System Online</p>
        </div>
      </div>
    </div>
    <button
      id="ai-clear-btn"
      class="text-slate-400 hover:text-white hover:bg-white/10 p-2.5 rounded-xl transition-all relative z-10"
      title="清除对话"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
    </button>
  </div>

  <!-- Chat Area -->
  <div id="chat-container" class="flex-1 p-4 overflow-y-auto space-y-4 bg-slate-50 relative">
    <div id="scroll-btn" class="hidden absolute bottom-4 right-4 bg-primary-600 hover:bg-primary-700 text-white p-2 rounded-full shadow-lg transition-all duration-200 z-10 cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
    <div id="messages-list" class="space-y-4"></div>
    <div id="typing-indicator" class="hidden">
      <div class="flex w-full justify-start">
        <div class="flex max-w-[85%] gap-3 flex-row">
          <div class="w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="bg-white p-3.5 rounded-2xl rounded-tl-none border border-gray-100 shadow-sm">
            <div class="flex space-x-1.5">
              <div class="w-2 h-2 bg-gray-300 rounded-full animate-bounce"></div>
              <div class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
              <div class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div id="messages-end"></div>
  </div>

  <!-- Input Area -->
  <div class="p-4 bg-white border-t border-gray-100">
    <div class="relative flex items-center gap-2">
      <input
        id="ai-input"
        type="text"
        placeholder="我想找一张吃饭打折多的卡..."
        class="flex-1 border border-gray-300 rounded-lg pl-4 pr-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
      <button
        id="ai-send-btn"
        class="bg-primary-600 text-white p-3 rounded-lg hover:bg-primary-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex-shrink-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
      </button>
    </div>
    <p class="text-xs text-gray-400 mt-2 text-center">AI 建议仅供参考，申请前请详细阅读银行条款。</p>
  </div>
</div>

<script>
  const container = document.getElementById('chat-container');
  const messagesList = document.getElementById('messages-list');
  const input = document.getElementById('ai-input') as HTMLInputElement;
  const sendBtn = document.getElementById('ai-send-btn');
  const clearBtn = document.getElementById('ai-clear-btn');
  const typing = document.getElementById('typing-indicator');
  const scrollBtn = document.getElementById('scroll-btn');
  const messagesEnd = document.getElementById('messages-end');

  let messages: { role: string; text: string }[] = [
    { role: 'model', text: '你好！我是你的智能选卡助手。告诉我你的消费习惯，或者直接提出你的需求（例如"我想找张旅行卡"），我会通过几个简单的问题帮你找到最合适的选择。' }
  ];
  let isLoading = false;

  function renderMessages() {
    if (!messagesList) return;
    messagesList.innerHTML = messages.map((msg, index) => `
      <div class="flex w-full ${msg.role === 'user' ? 'justify-end' : 'justify-start'}">
        <div class="flex max-w-[85%] gap-3 ${msg.role === 'user' ? 'flex-row-reverse' : 'flex-row'}">
          <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${msg.role === 'user' ? 'bg-indigo-100 text-indigo-600' : 'bg-green-100 text-green-600'}">
            ${msg.role === 'user'
              ? '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>'
              : '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>'
            }
          </div>
          <div class="p-3.5 rounded-2xl text-sm leading-relaxed whitespace-pre-wrap shadow-sm ${msg.role === 'user' ? 'bg-white text-slate-800 rounded-tr-none border border-gray-100' : 'bg-white text-slate-800 rounded-tl-none border border-gray-100'}">
            ${msg.text}
          </div>
        </div>
      </div>
    `).join('');
    scrollToBottom();
  }

  function scrollToBottom() {
    if (messagesEnd && container) {
      const containerRect = container.getBoundingClientRect();
      const endRect = messagesEnd.getBoundingClientRect();
      const scrollDistance = endRect.top - containerRect.top + container.scrollTop;
      container.scrollTo({ top: scrollDistance, behavior: 'smooth' });
    }
  }

  function handleSend() {
    const text = input?.value.trim();
    if (!text || isLoading) return;
    if (input) input.value = '';

    messages.push({ role: 'user', text });
    renderMessages();
    isLoading = true;
    typing?.classList.remove('hidden');

    // Simulate AI response
    setTimeout(() => {
      isLoading = false;
      typing?.classList.add('hidden');
      messages.push({
        role: 'model',
        text: '感谢您的提问！根据您的需求，我推荐您关注以下几张卡片：\n\n1. **招商银行 Young卡** - 适合年轻用户，餐饮优惠多\n2. **中信银行 IHG联名卡** - 酒店积分累积快\n3. **广发银行 多利白金卡** - 返现比例高\n\n您可以点击卡片查看详细评测，或者告诉我更多关于您的消费习惯，我可以给出更精准的建议。'
      });
      renderMessages();
    }, 1500);
  }

  function handleClear() {
    messages = [
      { role: 'model', text: '你好！我是你的智能选卡助手。告诉我你的消费习惯，或者直接提出你的需求（例如"我想找张旅行卡"），我会通过几个简单的问题帮你找到最合适的选择。' }
    ];
    if (input) input.value = '';
    isLoading = false;
    typing?.classList.add('hidden');
    renderMessages();
  }

  sendBtn?.addEventListener('click', handleSend);
  clearBtn?.addEventListener('click', handleClear);
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });

  scrollBtn?.addEventListener('click', scrollToBottom);

  if (container) {
    container.addEventListener('scroll', () => {
      const { scrollTop, scrollHeight, clientHeight } = container;
      const isNearBottom = scrollHeight - scrollTop - clientHeight < 100;
      if (!isNearBottom && scrollTop > 100) {
        scrollBtn?.classList.remove('hidden');
      } else {
        scrollBtn?.classList.add('hidden');
      }
    });
  }

  renderMessages();
</script>
