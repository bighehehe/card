---
import type { CreditCard } from '../types';
import { CardCategory } from '../types';

interface Props {
  card: CreditCard;
}

const { card } = Astro.props;

const categoryColors: Record<string, string> = {
  [CardCategory.CASHBACK]: 'bg-orange-100 text-orange-700',
  [CardCategory.TRAVEL]: 'bg-blue-100 text-blue-700',
  [CardCategory.PREMIUM]: 'bg-purple-100 text-purple-700',
  [CardCategory.STUDENT]: 'bg-pink-100 text-pink-700',
  [CardCategory.NO_FEE]: 'bg-green-100 text-green-700',
};

const stars = Array.from({ length: 5 }, (_, i) => i < Math.floor(card.rating));
---

<div class="card-hover bg-white rounded-2xl border border-slate-200/60 shadow-sm overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-0 md:gap-6">
    <!-- Image Section (Mobile Top / Desktop Left) -->
    <div class="md:col-span-3 bg-gray-50 p-6 flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-gray-100 relative group cursor-pointer">
      <a href={`/card/${card.id}`} class="relative w-full max-w-[240px] aspect-[1.58] shadow-lg rounded-lg overflow-hidden mb-4">
        <img src={card.image} alt={card.name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
      </a>
      <div class="text-center">
        <div class="flex items-center gap-0.5">
          {stars.map((filled) => (
            <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 ${filled ? 'text-yellow-400' : 'text-gray-300'}`} viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="md:col-span-6 p-6 flex flex-col justify-between">
      <div>
        <div class="flex flex-wrap gap-2 mb-2">
          {card.category.map((cat) => (
            <span class={`text-xs font-semibold px-2 py-1 rounded-md ${categoryColors[cat] || 'bg-gray-100 text-gray-700'}`}>
              {cat}
            </span>
          ))}
        </div>
        <a href={`/card/${card.id}`} class="text-xl font-bold text-slate-900 mb-1 flex items-center gap-2 hover:text-primary-600 transition-colors">
          {card.name}
        </a>
        <p class="text-sm text-slate-500 mb-4 font-medium">{card.bank}</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">年费政策</p>
            <p class="text-sm font-medium text-slate-900 mt-1">{card.annualFee}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">新户好礼</p>
            <p class="text-sm font-medium text-primary-700 mt-1">{card.welcomeBonus}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">积分比例</p>
            <p class="text-sm font-medium text-slate-900 mt-1">{card.features.rewardsRate}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">境外手续费</p>
            <p class="text-sm font-medium text-slate-900 mt-1">{card.features.foreignTxFee}</p>
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
            </svg>
            <p class="text-sm text-slate-700"><span class="font-bold">优点：</span> {card.pros.join('；')}</p>
          </div>
          <div class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-slate-500"><span class="font-bold">缺点：</span> {card.cons.join('；')}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Section -->
    <div class="md:col-span-3 p-6 bg-gray-50/50 flex flex-col justify-center items-center space-y-4 border-t md:border-t-0 md:border-l border-gray-100">
      <div class="text-center">
        <p class="text-xs text-gray-500 mb-1">建议信用评分</p>
        <p class="text-sm font-bold text-slate-900">{card.features.creditScoreReq}</p>
      </div>
      <button type="button" data-open-lead-modal data-card-name={card.name} class="w-full text-center bg-blue-600 hover:bg-blue-500 text-white font-semibold py-2.5 rounded-lg transition-colors shadow-sm cursor-pointer">
        立即申请
      </button>

      <button
        class="flex items-center justify-center gap-2 text-sm font-medium w-full py-2 rounded-lg transition-colors text-slate-600 hover:text-primary-600 hover:bg-gray-100"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <span>加入对比</span>
      </button>

      <a href={`/card/${card.id}`} class="w-full text-center text-slate-500 hover:text-slate-700 text-sm font-medium py-2 rounded-lg hover:bg-gray-100 transition-colors flex items-center justify-center gap-1">
        查看完整评测
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <p class="text-[10px] text-gray-400 text-center px-2">
        *具体审批结果以银行最终审核为准
      </p>
    </div>
  </div>
</div>
