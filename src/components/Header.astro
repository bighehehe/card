---
---
<header class="sticky top-0 z-50 glass-effect border-b border-white/20 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center cursor-pointer group">
        <div class="bg-blue-600 p-1.5 rounded-lg shadow-lg group-hover:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
        </div>
        <span class="ml-2 text-xl font-bold text-slate-900 tracking-tight font-display">CardWise <span class="text-primary-600">CN</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-slate-600 hover:text-primary-600 font-medium transition-colors">信用卡</a>
        <a href="/ranking" class="text-slate-600 hover:text-primary-600 font-medium transition-colors">排行榜</a>
        <a href="/promotions" class="text-slate-600 hover:text-primary-600 font-medium transition-colors">银行活动</a>
        <a href="/guides" class="text-slate-600 hover:text-primary-600 font-medium transition-colors">玩卡攻略</a>
      </nav>

      <!-- Desktop Actions -->
      <div class="hidden md:flex items-center space-x-4">
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            placeholder="搜索卡片..."
            class="pl-10 pr-4 py-1.5 border border-gray-300 rounded-full text-sm focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none w-48 transition-all"
          />
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center gap-4">
        <button id="mobile-menu-btn" class="text-gray-500 hover:text-gray-700 p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href="/" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:bg-gray-50 hover:text-primary-600">信用卡</a>
      <a href="/ranking" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:bg-gray-50 hover:text-primary-600">排行榜</a>
      <a href="/promotions" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:bg-gray-50 hover:text-primary-600">银行活动</a>
      <a href="/guides" class="block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:bg-gray-50 hover:text-primary-600">玩卡攻略</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
