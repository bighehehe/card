---
---
<section class="mesh-gradient text-white py-20 sm:py-28 overflow-hidden relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
    <div class="animate-fade-in-up">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight leading-tight mb-6">
        选对信用卡，<br />
        <span class="gradient-text">生活更精彩。</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-lg leading-relaxed">
        无论您是为了机场贵宾厅、返现权益，还是白金卡特权，<br />
        <span class="text-white font-medium">CardWise CN</span> 帮您精准对比，睿智选择。
      </p>
      <div class="flex flex-col sm:flex-row gap-5">
        <a href="/ranking" class="bg-primary-500 hover:bg-primary-400 text-white font-bold py-4 px-10 rounded-xl transition-all shadow-lg shadow-primary-500/20 text-lg hover:-translate-y-1 active:scale-95 inline-block text-center">
          浏览热门榜单
        </a>
        <button class="bg-emerald-500 hover:bg-emerald-400 text-white font-bold py-4 px-10 rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-lg hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          立即办卡
        </button>
        <button class="bg-slate-800/50 backdrop-blur border border-slate-700 hover:border-slate-500 text-white font-semibold py-4 px-10 rounded-xl transition-all hover:bg-slate-800">
          AI 智能选卡
        </button>
      </div>
      <div class="mt-12 flex flex-wrap items-center gap-8 text-sm text-slate-400">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>中立客观</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>全量卡库</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>动态权益</span>
        </div>
      </div>
    </div>
    <div class="hidden lg:block relative perspective-1000">
      <div class="relative mx-auto w-full max-w-md aspect-[1.586] bg-gradient-to-br from-primary-500 via-emerald-600 to-indigo-600 rounded-2xl shadow-2xl p-8 animate-float border border-white/20">
        <div class="flex justify-between items-start">
          <div class="w-16 h-12 bg-gradient-to-br from-yellow-300 to-amber-500 rounded-lg shadow-inner flex items-center justify-center overflow-hidden relative">
            <div class="w-full h-[1px] bg-black/10 rotate-45 transform scale-x-150 absolute"></div>
            <div class="w-full h-[1px] bg-black/10 -rotate-45 transform scale-x-150 absolute"></div>
          </div>
          <div class="text-white/40 text-sm font-mono tracking-tighter">PLATINUM WORLD</div>
        </div>

        <div class="mt-16">
          <div class="flex gap-4 mb-4">
            <div class="w-10 h-1 bg-white/20 rounded"></div>
            <div class="w-10 h-1 bg-white/20 rounded"></div>
            <div class="w-10 h-1 bg-white/20 rounded"></div>
            <div class="w-10 h-1 bg-white/20 rounded"></div>
          </div>
          <div class="text-2xl font-mono tracking-[0.2em] text-white/90 drop-shadow-md">
            •••• •••• •••• 8888
          </div>
        </div>

        <div class="mt-10 flex justify-between items-end">
          <div class="space-y-1">
            <div class="text-[10px] text-white/40 font-mono">CARDHOLDER NAME</div>
            <div class="text-white font-mono tracking-widest text-sm">CARDWISE USER</div>
          </div>
          <div class="flex -space-x-4">
            <div class="w-10 h-10 rounded-full bg-red-500/80 mix-blend-screen"></div>
            <div class="w-10 h-10 rounded-full bg-amber-500/80 mix-blend-screen"></div>
          </div>
        </div>

        <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/10 to-transparent rounded-2xl pointer-events-none"></div>
      </div>

      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] bg-indigo-500/20 blur-[120px] rounded-full -z-10 animate-pulse"></div>
    </div>
  </div>
</section>
