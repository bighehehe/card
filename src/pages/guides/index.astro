---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const articles = await getCollection('articles');
const sortedArticles = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = [
  { name: '全部', icon: 'BookOpen' },
  { name: '新手入门', icon: 'Compass' },
  { name: '里程兑换', icon: 'Plane' },
  { name: '权益攻略', icon: 'CreditCard' },
  { name: '避坑指南', icon: 'ShieldCheck' },
  { name: '银行专篇', icon: 'Building' },
  { name: '进阶玩法', icon: 'Zap' },
];

const featuredArticle = sortedArticles[0];
---

<Layout title="玩卡攻略 - CardWise CN">
  <Header />
  <main class="flex-grow bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-6">
        <a href="/" class="text-slate-500 hover:text-primary-600 text-sm font-medium flex items-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          返回首页
        </a>
      </div>

      {featuredArticle && (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-12 relative">
          <div class="grid grid-cols-1 md:grid-cols-2">
            <div class="p-8 md:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-2 text-primary-600 font-bold mb-4 uppercase tracking-wider text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                <span>本周精选</span>
              </div>
              <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-6 leading-tight">
                <a href={`/guides/${featuredArticle.id}`} class="hover:text-primary-700 transition-colors">
                  {featuredArticle.data.title}
                </a>
              </h1>
              <p class="text-lg text-slate-600 mb-8 leading-relaxed line-clamp-3">
                {featuredArticle.data.summary}
              </p>
              <div class="flex gap-4">
                <a href={`/guides/${featuredArticle.id}`} class="bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 px-8 rounded-xl transition-colors inline-block">
                  阅读全文
                </a>
                {sortedArticles[1] && (
                  <a href={`/guides/${sortedArticles[1].id}`} class="border border-gray-300 hover:border-primary-500 text-slate-700 hover:text-primary-600 font-semibold py-3 px-8 rounded-xl transition-colors inline-block">
                    查看更多精选
                  </a>
                )}
              </div>
            </div>
            <div class="bg-gray-100 h-64 md:h-auto relative">
              <img src={featuredArticle.data.image} class="w-full h-full object-cover" alt={featuredArticle.data.title} />
              <div class="absolute inset-0 bg-gradient-to-r from-white/20 to-transparent md:from-transparent"></div>
            </div>
          </div>
        </div>
      )}

      <div class="flex flex-wrap gap-4 mb-10 pb-4 border-b border-gray-200" id="category-filters">
        {categories.map((cat) => (
          <button
            data-category={cat.name}
            class={`category-btn flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-all ${cat.name === '全部' ? 'bg-slate-900 text-white shadow-md' : 'bg-white text-slate-600 hover:bg-gray-50'}`}
          >
            {cat.name}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16" id="articles-grid">
        {sortedArticles.map(article => (
          <a
            href={`/guides/${article.id}`}
            class="article-card bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow group"
            data-category={article.data.category}
          >
            <div class="relative h-48 overflow-hidden">
              <img src={article.data.image} alt={article.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-slate-800 shadow-sm">
                {article.data.category}
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-xs text-slate-400 mb-3">
                <span>{article.data.date}</span>
                <span>•</span>
                <span>{article.data.readTime} 阅读</span>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-primary-600 transition-colors line-clamp-2">
                {article.data.title}
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed mb-4 line-clamp-3">
                {article.data.summary}
              </p>
              <div class="flex items-center text-primary-600 text-sm font-semibold group-hover:underline">
                阅读更多
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="bg-slate-900 rounded-2xl p-8 md:p-12 text-center text-white relative overflow-hidden">
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold mb-4">不错过任何一个薅羊毛的机会</h2>
          <p class="text-slate-300 mb-8">订阅 CardWise CN 每周简报，获取最新的信用卡活动、突发神卡和积分贬值预警。</p>
          <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input type="email" placeholder="您的电子邮箱" class="flex-1 px-4 py-3 rounded-lg text-slate-900 focus:ring-2 focus:ring-primary-500 outline-none" />
            <button class="bg-primary-600 hover:bg-primary-500 text-white font-bold py-3 px-6 rounded-lg transition-colors shrink-0">
              立即订阅
            </button>
          </div>
        </div>
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary-600/20 to-transparent"></div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const cards = document.querySelectorAll<HTMLAnchorElement>('.article-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category || '全部';

      buttons.forEach(b => {
        b.classList.remove('bg-slate-900', 'text-white', 'shadow-md');
        b.classList.add('bg-white', 'text-slate-600');
      });
      btn.classList.remove('bg-white', 'text-slate-600');
      btn.classList.add('bg-slate-900', 'text-white', 'shadow-md');

      cards.forEach(card => {
        const cat = card.dataset.category || '';
        if (selected === '全部' || cat === selected) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
