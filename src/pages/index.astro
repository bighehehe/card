---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CardList from '../components/CardList.astro';
import AIAdvisor from '../components/AIAdvisor.astro';
import Footer from '../components/Footer.astro';
import { MOCK_CARDS } from '../data/cards';
---

<Layout>
  <Header />
  <Hero />
  <main class="flex-grow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <CardList />
        </div>
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <AIAdvisor />
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
              <h3 class="font-bold text-slate-900 mb-4">热门推荐</h3>
              <div class="space-y-4">
                {MOCK_CARDS.slice(0, 3).map(c => (
                  <a href={`/card/${c.id}`} class="flex gap-3 items-center cursor-pointer group">
                    <img src={c.image} class="w-12 h-8 rounded object-cover border border-gray-100" alt={c.name} />
                    <div>
                      <p class="text-sm font-medium text-slate-800 group-hover:text-primary-600 line-clamp-1">{c.name}</p>
                      <p class="text-xs text-slate-500">{c.bank}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
