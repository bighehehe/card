---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MOCK_CARDS } from '../data/cards';

const promotions = [
  {
    id: 1,
    bank: '招商银行',
    title: '周三5折美食日',
    description: '每周三指定餐饮商户消费享5折优惠，最高立减50元。覆盖海底捞、西贝莜面村等热门品牌。',
    period: '2024.01.01 - 2024.12.31',
    tags: ['餐饮', '周三专享'],
    color: 'from-red-500 to-pink-600',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
  {
    id: 2,
    bank: '交通银行',
    title: '最红星期五',
    description: '每周五超市、加油消费秒减5%，每月最高可减100元。沃尔玛、家乐福、中石化等均可参与。',
    period: '2024.01.01 - 2024.12.31',
    tags: ['超市', '加油', '周五专享'],
    color: 'from-blue-500 to-indigo-600',
    icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    id: 3,
    bank: '中信银行',
    title: '9分享兑',
    description: '每月任意消费9天，即可获得1次9积分兑换权益。可兑换星巴克、爱奇艺月卡、京东E卡等好礼。',
    period: '长期有效',
    tags: ['积分兑换', '月月享'],
    color: 'from-purple-500 to-violet-600',
    icon: 'M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7',
  },
  {
    id: 4,
    bank: '广发银行',
    title: '超级广发日',
    description: '周五美团、星巴克消费返现10%，每月最高返现100元。无需报名，消费自动返现。',
    period: '2024.01.01 - 2024.12.31',
    tags: ['返现', '美团', '星巴克'],
    color: 'from-orange-500 to-amber-600',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    id: 5,
    bank: '建设银行',
    title: '龙卡星期六',
    description: '每周六在指定商户消费满100减50，涵盖电影、餐饮、购物等多个场景。每月限享2次。',
    period: '2024.01.01 - 2024.12.31',
    tags: ['周六专享', '满减'],
    color: 'from-emerald-500 to-teal-600',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    id: 6,
    bank: '工商银行',
    title: '爱购周末',
    description: '周末在指定百货、超市消费享8折优惠，最高立减30元。覆盖万达、银泰等大型商场。',
    period: '2024.01.01 - 2024.12.31',
    tags: ['周末专享', '百货'],
    color: 'from-rose-500 to-red-600',
    icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',
  },
];

const featuredCards = MOCK_CARDS.filter(c =>
  ['cmb-young', 'cmb-diamond', 'citic-marriott', 'cgb-duoli'].includes(c.id)
);
---

<Layout title="银行活动 - CardWise CN">
  <Header />
  <main class="flex-grow bg-gray-50">
    <!-- Hero Section -->
    <div class="bg-slate-900 text-white py-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary-600/20 to-transparent"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="mb-6">
          <a href="/" class="text-slate-400 hover:text-white text-sm font-medium flex items-center transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            返回首页
          </a>
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
          银行优惠活动
        </h1>
        <p class="text-lg text-slate-300 max-w-2xl">
          汇总各大银行信用卡最新优惠活动，帮您省钱省心，不错过任何一个薅羊毛的机会。
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Featured Cards Banner -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          热门活动卡片推荐
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredCards.map(card => (
            <a href={`/card/${card.id}`} class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg transition-shadow group">
              <div class="flex items-center gap-3 mb-3">
                <img src={card.image} alt={card.name} class="w-12 h-8 object-cover rounded" />
                <div>
                  <p class="text-sm font-bold text-slate-900 group-hover:text-primary-600 transition-colors line-clamp-1">{card.name}</p>
                  <p class="text-xs text-slate-500">{card.bank}</p>
                </div>
              </div>
              <div class="flex flex-wrap gap-1">
                {card.tags.slice(0, 2).map(tag => (
                  <span class="text-[10px] bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Promotions Grid -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          当前热门活动
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {promotions.map(promo => (
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
              <div class={`bg-gradient-to-r ${promo.color} p-4 text-white`}>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d={promo.icon} />
                      </svg>
                    </div>
                    <div>
                      <p class="text-xs font-medium opacity-90">{promo.bank}</p>
                      <h3 class="font-bold text-lg">{promo.title}</h3>
                    </div>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <p class="text-sm text-slate-600 leading-relaxed mb-4">{promo.description}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {promo.tags.map(tag => (
                    <span class="text-xs bg-primary-50 text-primary-700 px-2 py-1 rounded-md font-medium">{tag}</span>
                  ))}
                </div>
                <div class="flex items-center gap-2 text-xs text-slate-400 pt-3 border-t border-gray-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>活动时间：{promo.period}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Tips Section -->
      <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-8 text-white relative overflow-hidden">
        <div class="relative z-10">
          <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            活动参与小贴士
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <h4 class="font-semibold mb-2 text-primary-400">提前报名</h4>
              <p class="text-sm text-slate-300">部分活动需要提前在App内报名，建议每周一检查当周活动并报名。</p>
            </div>
            <div>
              <h4 class="font-semibold mb-2 text-primary-400">注意名额</h4>
              <p class="text-sm text-slate-300">热门活动往往有名额限制，建议活动日当天尽早消费。</p>
            </div>
            <div>
              <h4 class="font-semibold mb-2 text-primary-400">叠加优惠</h4>
              <p class="text-sm text-slate-300">部分活动可与商户自身优惠叠加，消费前可咨询店员。</p>
            </div>
          </div>
        </div>
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary-600/10 rounded-full blur-3xl"></div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
