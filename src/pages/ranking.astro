---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MOCK_CARDS } from '../data/cards';
import { CardCategory } from '../types';

const rankingCategories = [
  CardCategory.TRAVEL,
  CardCategory.CASHBACK,
  CardCategory.PREMIUM,
  CardCategory.NO_FEE
];

const categoryIcons: Record<string, string> = {
  [CardCategory.TRAVEL]: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  [CardCategory.CASHBACK]: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  [CardCategory.PREMIUM]: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  [CardCategory.NO_FEE]: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
};

const currentDate = new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
---

<Layout title="排行榜 - CardWise CN">
  <Header />
  <main class="flex-grow bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-6">
        <a href="/" class="text-slate-500 hover:text-primary-600 text-sm font-medium flex items-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          返回首页
        </a>
      </div>

      <div class="mb-10 text-center sm:text-left">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
          2024年最佳信用卡排行榜
        </h1>
        <p class="text-lg text-slate-600 mb-2 max-w-3xl">
          CardWise 编辑团队对比了市场上百张信用卡，为您精选出各领域的佼佼者。无论您是追求极致性价比还是高端权益，都能在这里找到答案。
        </p>
        <div class="flex items-center justify-center sm:justify-start gap-2 text-sm text-slate-400 mt-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span>最后更新于：{currentDate}</span>
        </div>
      </div>

      <!-- Category Tabs -->
      <div class="flex flex-wrap gap-3 mb-12 border-b border-gray-200 pb-6" id="ranking-tabs">
        {rankingCategories.map((cat) => (
          <button
            data-category={cat}
            class={`ranking-tab flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold transition-all duration-200 ${cat === CardCategory.TRAVEL ? 'bg-slate-900 text-white shadow-md transform scale-105' : 'bg-white text-slate-600 border border-gray-200 hover:bg-gray-50 hover:border-gray-300'}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={categoryIcons[cat]} />
            </svg>
            {cat}榜单
          </button>
        ))}
      </div>

      <!-- Ranking Cards -->
      <div id="ranking-content" class="space-y-10">
        {rankingCategories.map(cat => {
          const rankedCards = MOCK_CARDS
            .filter(card => card.category.includes(cat))
            .sort((a, b) => b.rating - a.rating)
            .slice(0, 5);
          
          return (
            <div data-category={cat} class={`ranking-section ${cat === CardCategory.TRAVEL ? '' : 'hidden'}`}>
              {rankedCards.map((card, index) => (
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden group mb-6">
                  <div class="bg-slate-50 border-b border-gray-100 px-6 py-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                    </svg>
                    <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">
                      最佳{card.tags[0]?.replace('适合', '') || '选择'}卡
                    </span>
                  </div>

                  <div class="p-6 md:p-8 grid grid-cols-1 md:grid-cols-12 gap-8">
                    <!-- Left: Image & Rating -->
                    <div class="md:col-span-3 flex flex-col items-center text-center">
                      <a href={`/card/${card.id}`} class="relative w-full max-w-[200px] aspect-[1.58] shadow-md rounded-lg overflow-hidden mb-4">
                        <img src={card.image} alt={card.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                      </a>
                      <div class="mb-2">
                        <div class="flex items-center gap-0.5">
                          {Array.from({ length: 5 }, (_, i) => i < Math.floor(card.rating)).map(filled => (
                            <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 ${filled ? 'text-yellow-400' : 'text-gray-300'}`} viewBox="0 0 20 20" fill="currentColor">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                          ))}
                        </div>
                      </div>
                      <a href={`/card/${card.id}`} class="text-sm text-primary-600 font-medium hover:underline mt-1">
                        阅读完整评测
                      </a>
                    </div>

                    <!-- Middle: Content -->
                    <div class="md:col-span-6 flex flex-col justify-center">
                      <div class="mb-4">
                        <a href={`/card/${card.id}`} class="text-2xl font-bold text-slate-900 mb-1 hover:text-primary-700 transition-colors block">
                          {card.name}
                        </a>
                        <p class="text-sm text-slate-500 font-medium">{card.bank}</p>
                      </div>

                      <div class="mb-4">
                        <h3 class="text-sm font-bold text-slate-900 mb-2 uppercase tracking-wide">入选理由</h3>
                        <ul class="space-y-2">
                          {card.pros.slice(0, 3).map((pro) => (
                            <li class="flex items-start gap-2 text-slate-700 text-sm leading-relaxed">
                              <div class="mt-1 min-w-[16px]">
                                <div class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center">
                                  <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                  </svg>
                                </div>
                              </div>
                              {pro}
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>

                    <!-- Right: Key Stats & CTA -->
                    <div class="md:col-span-3 bg-gray-50/50 rounded-xl p-5 border border-gray-100 flex flex-col justify-between h-full">
                      <div class="space-y-4 mb-6">
                        <div>
                          <p class="text-[10px] uppercase text-gray-400 font-bold mb-1">年费</p>
                          <p class="text-sm font-semibold text-slate-900 line-clamp-2">{card.annualFee}</p>
                        </div>
                        <div>
                          <p class="text-[10px] uppercase text-gray-400 font-bold mb-1">新户礼</p>
                          <p class="text-sm font-semibold text-primary-700 line-clamp-2">{card.welcomeBonus}</p>
                        </div>
                        <div>
                          <p class="text-[10px] uppercase text-gray-400 font-bold mb-1">信用要求</p>
                          <p class="text-sm font-semibold text-slate-900">{card.features.creditScoreReq}</p>
                        </div>
                      </div>
                      
                      <a href={`/card/${card.id}`} class="w-full text-center bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 rounded-lg transition-colors shadow-sm flex items-center justify-center gap-2 text-sm">
                        查看详情
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          );
        })}
      </div>

      <!-- SEO / Bottom Text -->
      <div class="mt-16 prose prose-slate max-w-none text-slate-500 text-sm">
        <h3 class="text-slate-800 font-bold text-lg mb-2">如何选择最适合您的信用卡？</h3>
        <p>
          在选择信用卡时，您应该重点关注里程兑换比例、机场贵宾厅权益以及境外交易手续费。CardWise CN 的评测模型综合考虑了年费政策、权益价值、持卡成本以及用户口碑，为您筛选出上述最佳选择。建议您根据自身的实际消费能力和征信状况理性申请。
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('.ranking-tab');
  const sections = document.querySelectorAll<HTMLDivElement>('.ranking-section');

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category || '';

      tabButtons.forEach(b => {
        b.classList.remove('bg-slate-900', 'text-white', 'shadow-md', 'transform', 'scale-105');
        b.classList.add('bg-white', 'text-slate-600', 'border', 'border-gray-200');
      });
      btn.classList.remove('bg-white', 'text-slate-600', 'border', 'border-gray-200');
      btn.classList.add('bg-slate-900', 'text-white', 'shadow-md', 'transform', 'scale-105');

      sections.forEach(section => {
        const cat = section.dataset.category || '';
        if (cat === selected) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });
    });
  });
</script>
